{
	"info": {
		"name": "Perfume Platform API",
		"description": "Colección completa de endpoints para la plataforma de perfumes con microservicios.\n\nBase URL: http://localhost:8080 (API Gateway)\n\nAutenticación:\n1. POST /api/auth/login → obtener JWT token\n2. Usar token en header Authorization: Bearer <token>",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth Service",
			"description": "Endpoints de autenticación y credenciales.\nGateway: /api/auth/* → /api/v1/auth/*",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@perfume.com\",\n  \"password\": \"123456\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						}
					}
				},
